<UserControl x:Class="SyntaxEditorExample.CustomLanguageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:set="clr-namespace:SyntaxEditor.Theming;assembly=SyntaxEditor"
             xmlns:se="clr-namespace:SyntaxEditor;assembly=SyntaxEditor"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <GroupBox Header="Language Name:"
                  Grid.ColumnSpan="2">
            <dxe:TextEdit Text="{Binding LanguageId, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
                          NullText="Enter a Language Name (letters, digits, '-' or '_'; case-sensitive)."/>
        </GroupBox>
       
        <GroupBox Header="Monarch:" Grid.Row="1" Margin="0,0,2,0">
            <se:SyntaxEditor Text="{Binding Monarch}" 
                                EditorLanguage="javascript" 
                                ShowLineNumbers="False">
                <dxmvvm:Interaction.Behaviors>
                    <set:ThemeBehavior />
                </dxmvvm:Interaction.Behaviors>
            </se:SyntaxEditor>
        </GroupBox>

        <GroupBox Header="Configuration:" Grid.Row="1" Grid.Column="1" Margin="2,0,0,0">
            <se:SyntaxEditor Text="{Binding Configuration}" EditorLanguage="javascript"
                                ShowLineNumbers="False">
                <dxmvvm:Interaction.Behaviors>
                    <set:ThemeBehavior />
                </dxmvvm:Interaction.Behaviors>
            </se:SyntaxEditor>
        </GroupBox>
      
    </Grid>
</UserControl>
